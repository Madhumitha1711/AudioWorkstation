# --- App ---
PORT=3000
# Comma-separated list of origins allowed to call this API (e.g. the
# studio-vr dev server). Leave unset to allow all origins in development.
CORS_ORIGINS=http://localhost:5173

# --- Database: Postgres via TypeORM ---
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=studio-db
DATABASE_SSL=false

# --- Studio CMS: Strapi ---
# Base URL of the studio-cms Strapi instance this service proxies.
STRAPI_BASE_URL=http://localhost:1337
# Server-side API token from Strapi (Settings -> API Tokens). Strapi's
# users-permissions plugin has been removed there on purpose, so every
# content-API request needs this token as `Authorization: Bearer <token>`.
# Treat it as a secret — never send it to studio-vr/the browser directly;
# that's the whole reason this proxy exists.
STRAPI_API_TOKEN=replace-with-a-real-token-from-strapi-admin-settings-api-tokens

# --- Auth: JWT session tokens ---
# Used to sign the token returned by /auth/signup, /auth/login and
# /auth/google. Generate a long random string for real deployments, e.g.
# `openssl rand -base64 48`. The fallback below is fine for local dev only.
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# --- Auth: Google Sign-In ---
# OAuth 2.0 Client ID from Google Cloud Console (APIs & Services ->
# Credentials -> Create Credentials -> OAuth client ID -> Web application).
# Must match VITE_GOOGLE_CLIENT_ID in studio-vr/.env. Leave unset to disable
# Google Sign-In server-side (POST /auth/google will 401).
GOOGLE_CLIENT_ID=

# --- Auth: AWS SES (forgot-password verification code emails) ---
# Leave any of these unset and the six-digit code is logged to the server
# console instead of emailed — handy for local dev without an AWS account.
# For a real deployment: verify SES_FROM_EMAIL (or its domain) in the SES
# console, and use an IAM user/role scoped to ses:SendEmail only.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=
