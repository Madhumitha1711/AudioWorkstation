# --- App ---
PORT=3000
# Comma-separated list of origins allowed to call this API (e.g. the
# studio-vr dev server). Leave unset to allow all origins in development.
CORS_ORIGINS=http://localhost:5173

# --- Database: Postgres via TypeORM ---
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=studio-db
DATABASE_SSL=false

# --- Studio CMS: Strapi ---
# Base URL of the studio-cms Strapi instance this service proxies.
STRAPI_BASE_URL=http://localhost:1337
# Server-side API token from Strapi (Settings -> API Tokens). Strapi's
# users-permissions plugin has been removed there on purpose, so every
# content-API request needs this token as `Authorization: Bearer <token>`.
# Treat it as a secret — never send it to studio-vr/the browser directly;
# that's the whole reason this proxy exists.
STRAPI_API_TOKEN=replace-with-a-real-token-from-strapi-admin-settings-api-tokens

# --- Auth: JWT session tokens ---
# Used to sign the token returned by /auth/signup, /auth/login and
# /auth/google. Generate a long random string for real deployments, e.g.
# `openssl rand -base64 48`. The fallback below is fine for local dev only.
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# --- Auth: Google Sign-In ---
# OAuth 2.0 Client ID from Google Cloud Console (APIs & Services ->
# Credentials -> Create Credentials -> OAuth client ID -> Web application).
# Must match VITE_GOOGLE_CLIENT_ID in studio-vr/.env. Leave unset to disable
# Google Sign-In server-side (POST /auth/google will 401).
GOOGLE_CLIENT_ID=

# --- Auth: AWS SES (forgot-password verification code emails) ---
# Leave any of these unset and the six-digit code is logged to the server
# console instead of emailed — handy for local dev without an AWS account.
# For a real deployment: verify SES_FROM_EMAIL (or its domain) in the SES
# console, and use an IAM user/role scoped to ses:SendEmail only.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=

# --- Auth: admin accounts ---
# Comma-separated list of emails that get promoted to role='admin' the
# next time that account signs up/logs in/uses Google sign-in (see
# AuthService.syncAdminRole). Admin accounts skip the payment gate
# entirely — see User.hasAccess and JwtAuthGuard. Promote-only: removing
# an email here later does NOT revoke admin from an account that already
# has it; that would need a direct database update.
ADMIN_EMAILS=

# --- Payments: full-course lifetime access, one-time purchase ---
# Every authenticated API route requires the signed-in user to have
# access (see JwtAuthGuard: User.hasAccess = hasPaid OR role==='admin')
# except the handful of routes marked @SkipPayment() — GET /auth/me and
# the /payments/* endpoints themselves. There is no way to reach
# /course, /studio content, etc. without this being satisfied.
#
# Price charged server-side (PaymentsService) — keep in sync with
# studio-vr/src/store/checkoutSlice.js's PRICE if you change it.
COURSE_PRICE_USD=199

# Which gateway is active for *new* orders. Both integrations are always
# available in the backend (see PaymentGatewayRegistry) — flipping this is
# a redeploy, not a code change. Valid values: razorpay | stripe
PAYMENT_GATEWAY=razorpay

# Base URL of the studio-vr frontend. Only used by the Stripe integration,
# to build the Checkout success/cancel redirect URLs — Razorpay's modal
# checkout never navigates away from the page so it doesn't need this.
FRONTEND_URL=http://localhost:5173

# --- Payments: Razorpay ---
# From the Razorpay dashboard: Settings -> API Keys for the first two,
# Settings -> Webhooks (add an endpoint pointing at
# <this API>/payments/webhook/razorpay, subscribed to at least
# payment.captured and payment.failed) for the webhook secret.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Payments: Stripe ---
# From the Stripe dashboard: Developers -> API Keys for the secret key,
# Developers -> Webhooks (add an endpoint pointing at
# <this API>/payments/webhook/stripe, subscribed to at least
# checkout.session.completed) for the webhook signing secret. No
# publishable key is needed — the frontend never talks to Stripe directly,
# it's redirected to a Stripe-hosted Checkout page instead (see
# StripeGateway).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
