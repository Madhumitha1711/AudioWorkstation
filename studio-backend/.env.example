# --- App ---
PORT=3000
# Comma-separated list of origins allowed to call this API (e.g. the
# studio-vr dev server). Leave unset to allow all origins in development.
CORS_ORIGINS=http://localhost:5173

# --- Database: Postgres via TypeORM ---
# Business logic (accounts, enrollment, progress, etc.) will live in this
# database later. Nothing reads/writes it yet.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=studio-db
DATABASE_SSL=false

# --- Studio CMS: Strapi ---
# Base URL of the studio-cms Strapi instance this service proxies.
STRAPI_BASE_URL=http://localhost:1337
# Server-side API token from Strapi (Settings -> API Tokens). Strapi's
# users-permissions plugin has been removed there on purpose, so every
# content-API request needs this token as `Authorization: Bearer <token>`.
# Treat it as a secret — never send it to studio-vr/the browser directly;
# that's the whole reason this proxy exists.
STRAPI_API_TOKEN=replace-with-a-real-token-from-strapi-admin-settings-api-tokens
