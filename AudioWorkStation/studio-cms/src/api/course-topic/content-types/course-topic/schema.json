{
  "kind": "collectionType",
  "collectionName": "course_topics",
  "info": {
    "singularName": "course-topic",
    "pluralName": "course-topics",
    "displayName": "Course Topic",
    "description": "A VR hotspot topic in the course curriculum (e.g. Speakers, Mixing Console, DAW Workstation), matching TOPICS[] in studio-vr's src/course/courseData.js."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "description": "Matches TOPICS[].id / roomsData.js marker.id, e.g. \"speaker\", \"daw-screens\"."
    },
    "title": {
      "type": "string",
      "required": true
    },
    "room": {
      "type": "string",
      "description": "Display name of the room this topic lives in, e.g. \"Control Room\" (matches TOPICS[].room)."
    },
    "intro": {
      "type": "text",
      "required": true
    },
    "ready": {
      "type": "boolean",
      "default": false,
      "description": "Whether the topic is live or shown as \"coming soon\" — matches TOPICS[].ready."
    },
    "order": {
      "type": "integer",
      "default": 0,
      "description": "Display/curriculum order; studio-vr's buildStepList() walks topics in this order."
    },
    "model3d": {
      "type": "component",
      "repeatable": false,
      "component": "shared.model-asset"
    },
    "lessons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lesson.lesson",
      "mappedBy": "topic"
    },
    "assessment": {
      "type": "component",
      "repeatable": false,
      "component": "course.assessment"
    },
    "interactive": {
      "type": "component",
      "repeatable": false,
      "component": "course.interactive-activity"
    }
  }
}
