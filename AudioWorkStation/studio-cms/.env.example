# JWT_SECRET removed: that var only mattered for the users-permissions
# plugin's end-user JWTs, which this project no longer uses (auth lives in
# the separate NestJS service). ADMIN_JWT_SECRET above is unrelated — it's
# for the Strapi admin panel login and is still required.

# --- Media storage: S3 (images, audio narration, docs, .glb scans) ---
# Used by config/plugins.ts (upload provider). Leave AWS_ENDPOINT unset for
# real AWS S3; set it for an S3-compatible service (Cloudflare R2, MinIO, etc).
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_FORCE_PATH_STYLE=false

# --- Video: Cloudflare Stream ---
# Strapi's upload plugin doesn't manage Cloudflare Stream directly — there is
# no Strapi-maintained provider for it. Instead, POST /api/lessons/:id/video
# (src/api/lesson/controllers/lesson.ts + src/utils/cloudflare-stream.ts)
# uploads the file to Stream server-to-server and writes the resulting UID
# onto that lesson's video.videoUid field. CLOUDFLARE_ACCOUNT_ID and
# CLOUDFLARE_STREAM_API_TOKEN are required for that route (and for
# GET /api/lessons/:id/video/status) to work; CUSTOMER_SUBDOMAIN is only
# needed if you build playback URLs (HLS manifest / iframe embed) yourself.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=

DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=studio-cms
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_SSL=false