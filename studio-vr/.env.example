# Base URL of the studio-backend NestJS API (see src/course/useCourseTopics.js
# and src/api/client.js).
VITE_API_BASE_URL=http://localhost:3000

# OAuth 2.0 Client ID from Google Cloud Console, used for the "Continue with
# Google" button (see src/components/GoogleAuthButton.jsx). Must match
# GOOGLE_CLIENT_ID in studio-backend/.env. Leave unset to show a disabled
# placeholder instead of the real Google button.
VITE_GOOGLE_CLIENT_ID=